    <a href="#" onclick="showPanel('contact-settings',this)"><i class="fas fa-address-book"></i> إعدادات التواصل</a>
    <a href="#" onclick="showPanel('hero-settings',this)"><i class="fas fa-home"></i> إعدادات البانر</a>
    <a href="#" onclick="showPanel('seo-settings',this)"><i class="fas fa-search"></i> إعدادات SEO</a>
    <a href="#" onclick="showPanel('users-panel',this)"><i class="fas fa-users-cog"></i> المستخدمون</a>
    <a href="#" onclick="showPanel('analytics-panel',this)"><i class="fas fa-chart-bar"></i> الإحصائيات</a>

    <div class="admin-nav-section">الحساب</div>
    <a href="#" onclick="changePass()"><i class="fas fa-key"></i> تغيير كلمة المرور</a>
    <a href="#" onclick="doLogout()" style="color:#ef9090"><i class="fas fa-sign-out-alt"></i> تسجيل الخروج</a>
  </div>
</div>

<!-- MAIN -->
<div class="admin-main">
  <div class="admin-header">
    <h1 id="adminPageTitle">لوحة التحكم الرئيسية</h1>
    <div class="admin-header-actions">
      <a href="#" onclick="goToSite()" class="admin-btn secondary"><i class="fas fa-eye"></i> عرض الموقع</a>
      <span style="font-size:13px;color:var(--gray-500)"><i class="fas fa-user-circle"></i> مرحباً، admin</span>
    </div>
  </div>

  <div class="admin-content">

    <!-- DASHBOARD -->
    <div class="admin-panel active" id="dashboard">
      <div class="stats-row">
        <div class="stat-box"><div class="stat-icon blue"><i class="fas fa-clipboard-list"></i></div><div class="stat-info"><div class="num" id="statReqs">0</div><div class="lbl">طلبات الخدمة</div></div></div>
        <div class="stat-box"><div class="stat-icon gold"><i class="fas fa-envelope"></i></div><div class="stat-info"><div class="num" id="statMsgs">0</div><div class="lbl">رسائل التواصل</div></div></div>
        <div class="stat-box"><div class="stat-icon green"><i class="fas fa-broom"></i></div><div class="stat-info"><div class="num" id="statSvcs">16</div><div class="lbl">الخدمات النشطة</div></div></div>
        <div class="stat-box"><div class="stat-icon red"><i class="fas fa-chart-line"></i></div><div class="stat-info"><div class="num" id="statClicks">0</div><div class="lbl">نقرات الاتصال</div></div></div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px">
        <div class="admin-card">
          <div class="admin-card-header"><h3>آخر طلبات الخدمة</h3><button class="admin-btn secondary" onclick="showPanel('requests-panel')">عرض الكل</button></div>
          <div class="admin-card-body" id="latestReqs" style="font-size:14px;color:var(--gray-500);text-align:center;padding:30px">لا توجد طلبات بعد</div>
        </div>
        <div class="admin-card">
          <div class="admin-card-header"><h3>آخر رسائل التواصل</h3><button class="admin-btn secondary" onclick="showPanel('messages-panel')">عرض الكل</button></div>
          <div class="admin-card-body" id="latestMsgs" style="font-size:14px;color:var(--gray-500);text-align:center;padding:30px">لا توجد رسائل بعد</div>
        </div>
      </div>
      <div class="admin-card" style="margin-top:24px">
        <div class="admin-card-header"><h3>إحصائيات النقرات</h3></div>
        <div class="admin-card-body">
          <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:20px">
            <div style="text-align:center;background:var(--gray-100);border-radius:var(--radius);padding:20px">
              <div style="font-size:32px;color:#25d366"><i class="fab fa-whatsapp"></i></div>
              <div style="font-size:28px;font-weight:900;color:var(--dark)" id="waClicks">0</div>
              <div style="font-size:13px;color:var(--gray-500)">نقرات واتساب</div>
            </div>
            <div style="text-align:center;background:var(--gray-100);border-radius:var(--radius);padding:20px">
              <div style="font-size:32px;color:var(--primary)"><i class="fas fa-phone"></i></div>
              <div style="font-size:28px;font-weight:900;color:var(--dark)" id="phoneClicks">0</div>
              <div style="font-size:13px;color:var(--gray-500)">نقرات الهاتف</div>
            </div>
            <div style="text-align:center;background:var(--gray-100);border-radius:var(--radius);padding:20px">
              <div style="font-size:32px;color:var(--gold)"><i class="fas fa-mouse-pointer"></i></div>
              <div style="font-size:28px;font-weight:900;color:var(--dark)" id="totalClicks2">0</div>
              <div style="font-size:13px;color:var(--gray-500)">إجمالي النقرات</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- CONTACT SETTINGS -->
    <div class="admin-panel" id="contact-settings">
      <div class="admin-card">
        <div class="admin-card-header"><h3><i class="fas fa-address-book"></i> إعدادات التواصل</h3></div>
        <div class="admin-card-body">
          <h4 style="color:var(--primary);margin-bottom:16px;font-size:15px">أرقام التواصل</h4>
          <div class="form-grid">
            <div class="form-group-admin"><label>رقم الهاتف الأساسي</label><input type="text" id="cs_phone1" placeholder="0550000000"></div>
            <div class="form-group-admin"><label>رقم هاتف إضافي</label><input type="text" id="cs_phone2" placeholder="اختياري"></div>
            <div class="form-group-admin"><label>رقم واتساب</label><input type="text" id="cs_wa" placeholder="966550000000"></div>
            <div class="form-group-admin"><label>رسالة واتساب الافتراضية</label><input type="text" id="cs_waMsg" placeholder="السلام عليكم، أود الاستفسار..."></div>
          </div>
          <h4 style="color:var(--primary);margin:20px 0 16px;font-size:15px">بيانات الشركة</h4>
          <div class="form-grid">
            <div class="form-group-admin"><label>البريد الإلكتروني الأساسي</label><input type="email" id="cs_email1" placeholder="info@alostora.com"></div>
            <div class="form-group-admin"><label>بريد إضافي</label><input type="email" id="cs_email2" placeholder="اختياري"></div>
            <div class="form-group-admin"><label>عنوان الشركة</label><input type="text" id="cs_address" placeholder="بريدة، القصيم"></div>
            <div class="form-group-admin"><label>ساعات العمل</label><input type="text" id="cs_hours" placeholder="السبت - الخميس: 7ص - 10م"></div>
            <div class="form-group-admin" style="grid-column:1/-1"><label>رابط Google Maps</label><input type="text" id="cs_map" placeholder="https://maps.google.com/..."></div>
          </div>
          <h4 style="color:var(--primary);margin:20px 0 16px;font-size:15px">السوشيال ميديا</h4>
          <div class="form-grid">
            <div class="form-group-admin"><label><i class="fab fa-facebook" style="color:#1877f2"></i> Facebook</label><input type="text" id="cs_fb" placeholder="رابط الصفحة"></div>
            <div class="form-group-admin"><label><i class="fab fa-instagram" style="color:#e4405f"></i> Instagram</label><input type="text" id="cs_ig" placeholder="رابط الحساب"></div>
            <div class="form-group-admin"><label><i class="fab fa-twitter" style="color:#1da1f2"></i> X / Twitter</label><input type="text" id="cs_tw" placeholder="رابط الحساب"></div>
            <div class="form-group-admin"><label><i class="fab fa-tiktok"></i> TikTok</label><input type="text" id="cs_tt" placeholder="رابط الحساب"></div>
            <div class="form-group-admin"><label><i class="fab fa-snapchat" style="color:#fffc00"></i> Snapchat</label><input type="text" id="cs_snap" placeholder="رابط الحساب"></div>
            <div class="form-group-admin"><label><i class="fab fa-youtube" style="color:#ff0000"></i> YouTube</label><input type="text" id="cs_yt" placeholder="رابط القناة"></div>
          </div>
          <button class="admin-btn primary" onclick="saveContactSettings()"><i class="fas fa-save"></i> حفظ إعدادات التواصل</button>
        </div>
      </div>
    </div>

    <!-- HERO SETTINGS -->
    <div class="admin-panel" id="hero-settings">
      <div class="admin-card">
        <div class="admin-card-header"><h3>إعدادات البانر الرئيسي</h3></div>
        <div class="admin-card-body">
          <div class="form-group-admin"><label>عنوان البانر الرئيسي</label><input type="text" id="heroTitle" value="خدمات نظافة احترافية في القصيم لمنزل يليق بك"></div>
          <div class="form-group-admin"><label>وصف البانر</label><textarea id="heroDesc">نقدم أرقى خدمات التنظيف المتكاملة للمنازل والفلل والشقق والمكاتب في منطقة القصيم</textarea></div>
          <div class="form-grid">
            <div class="form-group-admin"><label>نص زر الطلب</label><input type="text" id="heroCTA1" value="اطلب الخدمة الآن"></div>
            <div class="form-group-admin"><label>نص زر واتساب</label><input type="text" id="heroCTA2" value="تواصل واتساب"></div>
          </div>
          <h4 style="color:var(--primary);margin:16px 0;font-size:15px">الإحصائيات</h4>
          <div class="form-grid">
            <div class="form-group-admin"><label>إحصائية 1 (عدد العملاء)</label><input type="text" id="stat1" value="500+"></div>
            <div class="form-group-admin"><label>إحصائية 2 (سنوات الخبرة)</label><input type="text" id="stat2" value="5+"></div>
            <div class="form-group-admin"><label>إحصائية 3 (الخدمات)</label><input type="text" id="stat3" value="16"></div>
          </div>
          <button class="admin-btn primary" onclick="saveHeroSettings()"><i class="fas fa-save"></i> حفظ إعدادات البانر</button>
        </div>
      </div>
    </div>



    <!-- HOME MANAGER PANEL -->
    <div class="admin-panel" id="home-manager-panel">
      <div class="home-admin-actions">
        <button class="admin-btn primary" onclick="saveHomeSettings()"><i class="fas fa-save"></i> حفظ التعديلات</button>
        <button class="admin-btn secondary" onclick="previewHomePage()"><i class="fas fa-eye"></i> معاينة الصفحة الرئيسية</button>
        <button class="admin-btn danger" onclick="resetHomeDefaults()"><i class="fas fa-rotate-left"></i> استرجاع الافتراضي</button>
      </div>
      <div class="admin-card">
        <div class="admin-card-header"><h3><i class="fas fa-house-chimney" style="color:var(--gold)"></i> إدارة الصفحة الرئيسية</h3></div>
        <div class="admin-card-body">
          <div class="home-section-editor"><h4><i class="fas fa-star"></i> قسم Hero الرئيسي</h4>
            <div class="form-grid"><div class="form-group-admin"><label>الشارة العلوية Badge</label><input id="hm_hero_badge" type="text"></div><div class="form-group-admin"><label>صورة الـ Hero</label><input type="file" accept="image/*" onchange="uploadHomeImage(event,'hero','image')"><div class="admin-help">JPG/PNG/WebP حتى 5MB</div><img id="hm_hero_image_preview" class="img-preview-small" style="display:none"></div></div>
            <div class="form-group-admin"><label>عنوان Hero الرئيسي</label><textarea id="hm_hero_title"></textarea></div><div class="form-group-admin"><label>النص الوصفي في Hero</label><textarea id="hm_hero_desc"></textarea></div>
            <div class="form-grid"><div class="form-group-admin"><label>نص الزر الأول</label><input id="hm_hero_btn1_text" type="text"></div><div class="form-group-admin"><label>رابط الزر الأول</label><input id="hm_hero_btn1_link" type="text"></div><div class="form-group-admin"><label>نص الزر الثاني</label><input id="hm_hero_btn2_text" type="text"></div><div class="form-group-admin"><label>رابط الزر الثاني</label><input id="hm_hero_btn2_link" type="text"></div></div>
            <h4><i class="fas fa-chart-simple"></i> الإحصائيات الثلاثة</h4><div class="form-grid"><div class="form-group-admin"><label>رقم 1</label><input id="hm_stat1_num" type="text"></div><div class="form-group-admin"><label>وصف 1</label><input id="hm_stat1_label" type="text"></div><div class="form-group-admin"><label>رقم 2</label><input id="hm_stat2_num" type="text"></div><div class="form-group-admin"><label>وصف 2</label><input id="hm_stat2_label" type="text"></div><div class="form-group-admin"><label>رقم 3</label><input id="hm_stat3_num" type="text"></div><div class="form-group-admin"><label>وصف 3</label><input id="hm_stat3_label" type="text"></div></div>
          </div>
          <div class="home-section-editor"><h4><i class="fas fa-award"></i> قسم لماذا نحن</h4><div class="form-grid"><div class="form-group-admin"><label>Badge</label><input id="hm_why_badge" type="text"></div><div class="form-group-admin"><label>الصورة</label><input type="file" accept="image/*" onchange="uploadHomeImage(event,'why','image')"><img id="hm_why_image_preview" class="img-preview-small" style="display:none"></div></div><div class="form-group-admin"><label>العنوان</label><textarea id="hm_why_title"></textarea></div><div class="form-group-admin"><label>الوصف</label><textarea id="hm_why_desc"></textarea></div><div class="form-grid"><div class="form-group-admin"><label>شارة النسبة</label><input id="hm_why_badge_num" type="text"></div><div class="form-group-admin"><label>وصف الشارة</label><input id="hm_why_badge_label" type="text"></div></div><div class="repeater-head"><strong>المميزات</strong><button class="admin-btn gold" onclick="addHomeItem('whyFeatures')"><i class="fas fa-plus"></i> إضافة ميزة</button></div><div id="hm_whyFeatures_list" class="repeater-list"></div></div>
          <div class="home-section-editor"><h4><i class="fas fa-list-ol"></i> خطوات العمل</h4><div class="form-grid"><div class="form-group-admin"><label>Badge</label><input id="hm_steps_badge" type="text"></div><div class="form-group-admin"><label>عنوان القسم</label><input id="hm_steps_title" type="text"></div></div><div class="form-group-admin"><label>وصف القسم</label><textarea id="hm_steps_desc"></textarea></div><div class="repeater-head"><strong>الخطوات</strong><button class="admin-btn gold" onclick="addHomeItem('steps')"><i class="fas fa-plus"></i> إضافة خطوة</button></div><div id="hm_steps_list" class="repeater-list"></div></div>
          <div class="home-section-editor"><h4><i class="fas fa-images"></i> معرض الأعمال</h4><div class="form-grid"><div class="form-group-admin"><label>Badge</label><input id="hm_gallery_badge" type="text"></div><div class="form-group-admin"><label>عنوان القسم</label><input id="hm_gallery_title" type="text"></div></div><div class="form-group-admin"><label>وصف القسم</label><textarea id="hm_gallery_desc"></textarea></div><div class="repeater-head"><strong>صور المعرض</strong><button class="admin-btn gold" onclick="addHomeItem('gallery')"><i class="fas fa-upload"></i> رفع/إضافة صورة</button></div><div id="hm_gallery_list" class="repeater-list"></div></div>
          <div class="home-section-editor"><h4><i class="fas fa-map-marker-alt"></i> مناطق الخدمة</h4><div class="form-grid"><div class="form-group-admin"><label>Badge</label><input id="hm_areas_badge" type="text"></div><div class="form-group-admin"><label>عنوان القسم</label><input id="hm_areas_title" type="text"></div></div><div class="form-group-admin"><label>وصف القسم</label><textarea id="hm_areas_desc"></textarea></div><div class="repeater-head"><strong>المدن</strong><button class="admin-btn gold" onclick="addHomeItem('areas')"><i class="fas fa-plus"></i> إضافة مدينة</button></div><div id="hm_areas_list" class="repeater-list"></div></div>
          <div class="home-section-editor"><h4><i class="fas fa-bullhorn"></i> قسم CTA</h4><div class="form-group-admin"><label>العنوان</label><input id="hm_cta_title" type="text"></div><div class="form-group-admin"><label>الوصف</label><textarea id="hm_cta_desc"></textarea></div><div class="form-grid"><div class="form-group-admin"><label>نص الزر الأول</label><input id="hm_cta_btn1_text" type="text"></div><div class="form-group-admin"><label>رابط الزر الأول</label><input id="hm_cta_btn1_link" type="text"></div><div class="form-group-admin"><label>إظهار الزر الأول</label><select id="hm_cta_btn1_show"><option value="true">إظهار</option><option value="false">إخفاء</option></select></div><div class="form-group-admin"><label>نص الزر الثاني</label><input id="hm_cta_btn2_text" type="text"></div><div class="form-group-admin"><label>رابط الزر الثاني</label><input id="hm_cta_btn2_link" type="text"></div><div class="form-group-admin"><label>إظهار الزر الثاني</label><select id="hm_cta_btn2_show"><option value="true">إظهار</option><option value="false">إخفاء</option></select></div><div class="form-group-admin"><label>نص زر الاتصال</label><input id="hm_cta_btn3_text" type="text"></div><div class="form-group-admin"><label>رابط زر الاتصال</label><input id="hm_cta_btn3_link" type="text"></div><div class="form-group-admin"><label>إظهار زر الاتصال</label><select id="hm_cta_btn3_show"><option value="true">إظهار</option><option value="false">إخفاء</option></select></div></div></div>
          <div class="home-admin-actions"><button class="admin-btn primary" onclick="saveHomeSettings()"><i class="fas fa-save"></i> حفظ التعديلات</button><button class="admin-btn secondary" onclick="previewHomePage()"><i class="fas fa-eye"></i> معاينة الصفحة الرئيسية</button><button class="admin-btn danger" onclick="resetHomeDefaults()"><i class="fas fa-rotate-left"></i> استرجاع الافتراضي</button></div>
        </div>
      </div>
    </div>

    <!-- SERVICES PANEL -->
    <div class="admin-panel" id="services-panel">
      <div class="admin-card">
        <div class="admin-card-header">
          <h3>إدارة الخدمات</h3>
          <button class="admin-btn gold" onclick="showAddService()"><i class="fas fa-plus"></i> إضافة خدمة</button>
        </div>
        <div class="admin-card-body" style="padding:0">
          <table class="admin-table" id="servicesTable">
            <thead><tr><th>#</th><th>الخدمة</th><th>الوصف</th><th>الحالة</th><th>إجراءات</th></tr></thead>
            <tbody id="servicesTbody"></tbody>
          </table>
        </div>
      </div>

    </div>

    <!-- OFFERS PANEL -->
    <div class="admin-panel" id="offers-panel">
      <div class="admin-card">
        <div class="admin-card-header">
          <h3>إدارة العروض والباقات</h3>
          <button class="admin-btn gold" onclick="showAddOffer()"><i class="fas fa-plus"></i> إضافة عرض</button>
        </div>
        <div class="admin-card-body" style="padding:0">
          <table class="admin-table">
            <thead><tr><th>#</th><th>اسم الباقة</th><th>السعر القديم</th><th>السعر الجديد</th><th>الحالة</th><th>إجراءات</th></tr></thead>
            <tbody id="offersTbody"></tbody>
          </table>
        </div>
      </div>

    </div>

    <!-- TESTIMONIALS PANEL -->
    <div class="admin-panel" id="testimonials-panel">
      <div class="admin-card">
        <div class="admin-card-header">
          <h3>إدارة آراء العملاء</h3>
          <button class="admin-btn gold" onclick="showAddTestimonial()"><i class="fas fa-plus"></i> إضافة رأي</button>
        </div>
        <div class="admin-card-body" style="padding:0">
          <table class="admin-table">
            <thead><tr><th>#</th><th>اسم العميل</th><th>التقييم</th><th>المدينة</th><th>الحالة</th><th>إجراءات</th></tr></thead>
            <tbody id="testimonialsTbody"></tbody>
          </table>
        </div>
      </div>

    </div>

    <!-- FAQ PANEL -->
    <div class="admin-panel" id="faq-panel">
      <div class="admin-card">
        <div class="admin-card-header">
          <h3>إدارة الأسئلة الشائعة</h3>
          <button class="admin-btn gold" onclick="showAddFaq()"><i class="fas fa-plus"></i> إضافة سؤال</button>
        </div>
        <div class="admin-card-body" style="padding:0">
          <table class="admin-table">
            <thead><tr><th>#</th><th>السؤال</th><th>الفئة</th><th>إجراءات</th></tr></thead>
            <tbody id="faqTbody"></tbody>
          </table>
        </div>
      </div>

    </div>

    <!-- GALLERY PANEL -->
    <div class="admin-panel" id="gallery-panel">
      <div class="admin-card">
        <div class="admin-card-header"><h3>إدارة معرض الصور</h3><button class="admin-btn gold"><i class="fas fa-upload"></i> رفع صورة</button></div>
        <div class="admin-card-body">
          <div style="background:var(--gray-100);border:2px dashed var(--gray-200);border-radius:var(--radius);padding:40px;text-align:center;color:var(--gray-500)">
            <i class="fas fa-cloud-upload-alt" style="font-size:40px;display:block;margin-bottom:12px"></i>
            <p>اسحب الصور هنا أو انقر لاختيارها</p>
            <p style="font-size:12px;margin-top:8px">JPG, PNG - حد أقصى 5MB لكل صورة</p>
          </div>
          <div style="margin-top:20px;display:grid;grid-template-columns:repeat(4,1fr);gap:12px" id="galleryAdmin">
            <div style="aspect-ratio:1;background:var(--gray-100);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:12px;color:var(--gray-500)">لا توجد صور</div>
          </div>
        </div>
      </div>
    </div>

    <!-- BLOG PANEL -->
    <div class="admin-panel" id="blog-panel">
      <div class="admin-card">
        <div class="admin-card-header">
          <h3>إدارة المقالات</h3>
          <button class="admin-btn gold" onclick="showAddBlog()"><i class="fas fa-plus"></i> مقال جديد</button>
        </div>
        <div class="admin-card-body" style="padding:0">
          <table class="admin-table">
            <thead><tr><th>#</th><th>عنوان المقال</th><th>التصنيف</th><th>الحالة</th><th>إجراءات</th></tr></thead>
            <tbody id="blogTbody"></tbody>
          </table>
        </div>
      </div>

    </div>

    <!-- REQUESTS PANEL -->
    <div class="admin-panel" id="requests-panel">
      <div class="admin-card">
        <div class="admin-card-header">
          <h3>طلبات الخدمة</h3>
          <div style="display:flex;gap:8px">
            <button class="admin-btn success" onclick="exportCSV()"><i class="fas fa-file-excel"></i> تصدير CSV</button>
          </div>
        </div>
        <div style="padding:16px 24px;background:var(--gray-100);display:flex;gap:12px;flex-wrap:wrap">
          <select id="filterStatus" onchange="filterRequests()" style="padding:8px 12px;border-radius:8px;border:1.5px solid var(--gray-200);font-family:var(--font-main);font-size:13px">
            <option value="">كل الحالات</option><option value="new">جديد</option><option value="progress">قيد التواصل</option><option value="done">مكتمل</option><option value="cancel">ملغي</option>
          </select>
          <select id="filterCity" onchange="filterRequests()" style="padding:8px 12px;border-radius:8px;border:1.5px solid var(--gray-200);font-family:var(--font-main);font-size:13px">
            <option value="">كل المدن</option><option>بريدة</option><option>عنيزة</option><option>الرس</option>
          </select>
        </div>
        <div class="admin-card-body" style="padding:0;overflow-x:auto">
          <table class="admin-table">
            <thead><tr><th>#</th><th>الاسم</th><th>الجوال</th><th>المدينة</th><th>الخدمة</th><th>التاريخ</th><th>الحالة</th><th>إجراءات</th></tr></thead>
            <tbody id="requestsTbody"></tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- MESSAGES PANEL -->
    <div class="admin-panel" id="messages-panel">
      <div class="admin-card">
        <div class="admin-card-header"><h3>رسائل التواصل</h3></div>
        <div class="admin-card-body" style="padding:0;overflow-x:auto">
          <table class="admin-table">
            <thead><tr><th>#</th><th>الاسم</th><th>الجوال</th><th>الموضوع</th><th>تاريخ الإرسال</th><th>الحالة</th><th>إجراءات</th></tr></thead>
            <tbody id="messagesTbody"></tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- SEO SETTINGS -->
    <div class="admin-panel" id="seo-settings">
      <div class="admin-card">
        <div class="admin-card-header"><h3>إعدادات SEO</h3></div>
        <div class="admin-card-body">
          <div class="form-grid">
            <div class="form-group-admin"><label>اسم الموقع</label><input type="text" id="seoSite" value="الأسطورة رونق قلب الخليج"></div>
            <div class="form-group-admin"><label>Meta Title العام</label><input type="text" id="seoTitle" value="الأسطورة رونق قلب الخليج | شركة تنظيف في القصيم"></div>
          </div>
          <div class="form-group-admin"><label>Meta Description العامة</label><textarea id="seoDesc">شركة تنظيف احترافية في القصيم، خدمات تنظيف منازل وفلل وكنب وسجاد في بريدة وعنيزة والرس</textarea></div>
          <div class="form-group-admin"><label>الكلمات المفتاحية</label><textarea id="seoKeys" placeholder="كلمة1, كلمة2, كلمة3">شركة تنظيف بالقصيم, تنظيف منازل, تنظيف فلل, تنظيف كنب</textarea></div>
          <div class="form-group-admin"><label>كود Google Analytics</label><textarea id="seoGA" placeholder="UA-XXXXXXXXX-X أو G-XXXXXXXXXX"></textarea></div>
          <div class="form-group-admin"><label>كود Meta Pixel</label><textarea id="seoPx" placeholder="كود الفيسبوك بيكسل"></textarea></div>
          <div class="form-group-admin"><label>أكواد Header مخصصة</label><textarea id="seoHead" placeholder="أكواد تضاف في &lt;head&gt;"></textarea></div>
          <button class="admin-btn primary" onclick="saveSEO()"><i class="fas fa-save"></i> حفظ إعدادات SEO</button>
        </div>
      </div>
    </div>

    <!-- USERS PANEL -->
    <div class="admin-panel" id="users-panel">
      <div class="admin-card">
        <div class="admin-card-header">
          <h3><i class="fas fa-users-cog" style="color:var(--gold)"></i> إدارة المستخدمين</h3>
          <button class="admin-btn gold" onclick="toggleAddUserForm()"><i class="fas fa-plus"></i> إضافة مستخدم</button>
        </div>

        <!-- Users Table -->
        <div class="admin-card-body" style="padding:0">
          <table class="admin-table">
            <thead>
              <tr>
                <th>#</th>
                <th>الاسم الكامل</th>
                <th>اسم المستخدم</th>
                <th>البريد</th>
                <th>الصلاحية</th>
                <th>تاريخ الإضافة</th>
                <th>إجراءات</th>
              </tr>
            </thead>
            <tbody id="usersTbody">
              <!-- filled by JS -->
            </tbody>
          </table>
        </div>
      </div>


    </div>

    <!-- ANALYTICS PANEL -->
    <div class="admin-panel" id="analytics-panel">
      <div class="admin-card">
        <div class="admin-card-header"><h3>إحصائيات النقرات والتتبع</h3></div>
        <div class="admin-card-body">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:24px">
            <div style="background:var(--gray-100);border-radius:var(--radius);padding:20px;text-align:center">
              <i class="fab fa-whatsapp" style="font-size:36px;color:#25d366;display:block;margin-bottom:8px"></i>
              <div style="font-size:36px;font-weight:900;color:var(--dark)" id="waClicksA">0</div>
              <div style="color:var(--gray-500)">نقرات واتساب</div>
            </div>
            <div style="background:var(--gray-100);border-radius:var(--radius);padding:20px;text-align:center">
              <i class="fas fa-phone" style="font-size:36px;color:var(--primary);display:block;margin-bottom:8px"></i>
              <div style="font-size:36px;font-weight:900;color:var(--dark)" id="phoneClicksA">0</div>
              <div style="color:var(--gray-500)">نقرات الهاتف</div>
            </div>
          </div>
          <h4 style="margin-bottom:12px;color:var(--primary)">سجل النقرات</h4>
          <div style="overflow-x:auto">
            <table class="admin-table">
              <thead><tr><th>النوع</th><th>الصفحة</th><th>التاريخ والوقت</th></tr></thead>
              <tbody id="clickLog"></tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

  </div><!-- end admin-content -->
</div><!-- end admin-main -->
</div><!-- end admin-wrap -->

<script>
// ===================== DATABASE (localStorage) =====================
const DB = {
  get: (k) => { try { return JSON.parse(localStorage.getItem('alostora_'+k)) } catch(e) { return null } },
  set: (k,v) => localStorage.setItem('alostora_'+k, JSON.stringify(v)),
  push: (k,v) => { let arr = DB.get(k)||[]; arr.push({...v, id: Date.now()}); DB.set(k,arr); return arr; },
  update: (k,id,data) => { let arr = DB.get(k)||[]; const i=arr.findIndex(x=>x.id===id); if(i>-1){arr[i]={...arr[i],...data}; DB.set(k,arr);} },
  remove: (k,id) => { let arr=(DB.get(k)||[]).filter(x=>x.id!==id); DB.set(k,arr); },
};

// ===================== DEFAULT DATA =====================

const defaultHomeSettings = {
  hero:{badge:'الأسطورة رونق قلب الخليج',title:'خدمات نظافة احترافية في القصيم<br>لمنزل <span>يليق بك</span>',desc:'نقدم أرقى خدمات التنظيف المتكاملة للمنازل والفلل والشقق والمكاتب في منطقة القصيم. فريق مدرب، مواد آمنة، نتائج مضمونة، وأسعار تنافسية.',image:'',btn1:{text:'اطلب الخدمة الآن',link:'#'},btn2:{text:'تواصل واتساب',link:'https://wa.me/966550000000?text=السلام عليكم، أود الاستفسار عن خدمات التنظيف'},stats:[{num:'500+',label:'عميل راضٍ'},{num:'5+',label:'سنوات خبرة'},{num:'16',label:'خدمة متخصصة'}]},
  why:{badge:'لماذا نحن',title:'لماذا تختار<br><span class="text-gold">الأسطورة رونق قلب الخليج؟</span>',desc:'نحن لسنا مجرد شركة تنظيف، نحن شركاؤك في الحفاظ على بيئة منزلية صحية ونظيفة. نجمع بين الخبرة العالية والمواد الآمنة والفريق المدرب لنقدم لك أفضل تجربة تنظيف في القصيم.',image:'',badgeNum:'100%',badgeLabel:'رضا العملاء',features:[{icon:'fa-users',title:'فريق مدرب ومحترف',desc:'عمالة مدربة على أعلى مستوى من الكفاءة والأمانة'},{icon:'fa-leaf',title:'مواد آمنة وصديقة للبيئة',desc:'نستخدم منظفات آمنة لأسرتكم وأطفالكم وحيواناتكم الأليفة'},{icon:'fa-clock',title:'التزام بالمواعيد',desc:'نحترم وقتك ونلتزم بالموعد المحدد دائماً'},{icon:'fa-shield-alt',title:'ضمان الرضا الكامل',desc:'إذا لم تكن راضياً تماماً، سنعيد العمل مجاناً'},{icon:'fa-tags',title:'أسعار تنافسية وشفافة',desc:'لا رسوم خفية، أسعار واضحة قبل البدء بالعمل'}]},
  steps:{badge:'آلية العمل',title:'كيف <span class="text-gold">نعمل؟</span>',desc:'خطوات بسيطة للحصول على خدمة نظافة احترافية في منزلك',items:[{icon:'fa-phone-alt',title:'تواصل معنا',desc:'اتصل بنا أو تواصل عبر واتساب لطلب الخدمة'},{icon:'fa-clipboard-list',title:'نقيّم الاحتياج',desc:'يزورك فريقنا لتقييم المكان وتحديد الخدمة المناسبة'},{icon:'fa-broom',title:'ننفذ الخدمة',desc:'يبدأ فريقنا المحترف بتنفيذ الخدمة بأعلى معايير الجودة'},{icon:'fa-star',title:'رضاك مضمون',desc:'نتأكد من رضاك الكامل قبل مغادرة الفريق'}]},
  gallery:{badge:'معرض الأعمال',title:'أعمالنا <span class="text-gold">تتحدث عنا</span>',desc:'صور قبل وبعد من مشاريع نظافة حقيقية نفذناها في القصيم',items:[{title:'تنظيف كنب',cat:'كنب',icon:'fa-couch',image:''},{title:'تنظيف سجاد',cat:'سجاد',icon:'fa-rug',image:''},{title:'تنظيف شامل',cat:'منازل',icon:'fa-home',image:''},{title:'تنظيف مطبخ',cat:'مطابخ',icon:'fa-blender',image:''},{title:'تنظيف حمام',cat:'حمامات',icon:'fa-bath',image:''},{title:'تنظيف فيلا',cat:'فلل',icon:'fa-building',image:''},{title:'تعقيم وتطهير',cat:'تعقيم',icon:'fa-spray-can',image:''},{title:'تنظيف زجاج',cat:'زجاج',icon:'fa-window-maximize',image:''}]},
  areas:{badge:'مناطق الخدمة',title:'نخدم <span class="text-gold">جميع أنحاء القصيم</span>',desc:'نصلك أينما كنت في منطقة القصيم',items:[{icon:'🏙️',title:'بريدة',desc:'العاصمة الرئيسية'},{icon:'🌆',title:'عنيزة',desc:'مدينة الورود'},{icon:'🏘️',title:'الرس',desc:'المدينة التاريخية'},{icon:'🏡',title:'البكيرية',desc:'المدينة الزراعية'},{icon:'🌿',title:'المذنب',desc:'مدينة النخيل'},{icon:'🏗️',title:'البدائع',desc:'المدينة الحديثة'},{icon:'🌄',title:'رياض الخبراء',desc:'المدينة الجميلة'},{icon:'💧',title:'عيون الجواء',desc:'مدينة العيون'},{icon:'⭐',title:'الشماسية',desc:'مدينة التراث'}]},
  cta:{title:'جاهز لمنزل نظيف كالفندق؟',desc:'تواصل معنا الآن واحصل على عرض سعر مجاني خلال دقائق',buttons:[{text:'اطلب الخدمة الآن',link:'#',show:true,icon:'fa-calendar-check',class:'btn-gold'},{text:'تواصل واتساب',link:'https://wa.me/966550000000',show:true,icon:'fab fa-whatsapp',class:'btn-whatsapp'},{text:'اتصل الآن',link:'tel:0550000000',show:true,icon:'fa-phone',class:''}]}
};
function cloneHomeDefaults(){return JSON.parse(JSON.stringify(defaultHomeSettings));}
function getHomeSettings(){return DB.get('homeSettings')||cloneHomeDefaults();}
function setHtml(sel,html){const el=document.querySelector(sel);if(el)el.innerHTML=html;}
function setText(sel,txt){const el=document.querySelector(sel);if(el)el.textContent=txt;}
function setSectionTitle(sectionSel,data){const sec=document.querySelector(sectionSel);if(!sec||!data)return;const badge=sec.querySelector('.section-title .badge');if(badge)badge.innerHTML='<i class="fas fa-tag"></i> '+(data.badge||'');const h2=sec.querySelector('.section-title h2');if(h2)h2.innerHTML=data.title||'';const p=sec.querySelector('.section-title p');if(p)p.innerHTML=data.desc||'';}
function safeUrl(u){return u&&u.trim()?u.trim():'#';}
function renderManagedHome(){const h=getHomeSettings();setHtml('.hero-badge','<i class="fas fa-star"></i> '+(h.hero.badge||''));setHtml('.hero h2',h.hero.title||'');setText('.hero-desc',h.hero.desc||'');const hb=document.querySelectorAll('.hero-actions a');if(hb[0]){hb[0].href=safeUrl(h.hero.btn1?.link);hb[0].innerHTML='<i class="fas fa-calendar-check"></i> '+(h.hero.btn1?.text||'');}if(hb[1]){hb[1].href=safeUrl(h.hero.btn2?.link);hb[1].innerHTML='<i class="fab fa-whatsapp"></i> '+(h.hero.btn2?.text||'');}(h.hero.stats||[]).forEach((st,i)=>{const c=document.querySelectorAll('.hero-stats .stat-card')[i];if(c){c.querySelector('.num').textContent=st.num||'';c.querySelector('.lbl').textContent=st.label||'';}});const hi=document.querySelector('.hero-img-main');if(hi){hi.classList.toggle('img-placeholder',!h.hero.image);hi.innerHTML=h.hero.image?`<img src="${h.hero.image}" alt="${h.hero.badge||'Hero'}">`:'<i class="fas fa-home"></i><span>صورة فاخرة للتنظيف</span>';}setHtml('#why-us .why-text .badge','<i class="fas fa-award"></i> '+(h.why.badge||''));setHtml('#why-us .why-text h2',h.why.title||'');setText('#why-us .why-text > p',h.why.desc||'');const wf=document.querySelector('#why-us .why-features');if(wf)wf.innerHTML=(h.why.features||[]).map(f=>`<div class="why-feature"><div class="icon"><i class="fas ${f.icon||'fa-check'}"></i></div><div class="info"><h4>${f.title||''}</h4><p>${f.desc||''}</p></div></div>`).join('');const wi=document.querySelector('#why-us .why-img');if(wi){wi.classList.toggle('img-placeholder',!h.why.image);wi.innerHTML=h.why.image?`<img src="${h.why.image}" alt="${h.why.badge||'Why us'}">`:'<i class="fas fa-spray-can"></i><span>فريق العمل أثناء التنظيف</span>';}setText('#why-us .why-badge .num',h.why.badgeNum||'');setText('#why-us .why-badge .lbl',h.why.badgeLabel||'');setSectionTitle('#steps-section',h.steps);const sg=document.querySelector('#steps-section .steps-grid');if(sg)sg.innerHTML=(h.steps.items||[]).map(x=>`<div class="step-card"><div class="step-num"><i class="fas ${x.icon||'fa-check'}"></i></div><h3>${x.title||''}</h3><p>${x.desc||''}</p></div>`).join('');setSectionTitle('#gallery-section',h.gallery);const gg=document.querySelector('#gallery-section .gallery-grid');if(gg)gg.innerHTML=(h.gallery.items||[]).map(g=>`<div class="gallery-item ${g.image?'':'img-placeholder'}" style="aspect-ratio:4/3">${g.image?`<img src="${g.image}" alt="${g.title||''}">`:`<i class="fas ${g.icon||'fa-image'}"></i><span>${g.title||''}</span>`}<div class="gallery-overlay"><i class="fas fa-search-plus"></i></div></div>`).join('');setSectionTitle('#areas-section',h.areas);const ag=document.querySelector('#areas-section .areas-grid');if(ag)ag.innerHTML=(h.areas.items||[]).map(a=>`<div class="area-card"><div class="area-icon">${a.icon||'📍'}</div><h3>${a.title||''}</h3><p>${a.desc||''}</p></div>`).join('');setHtml('#cta-section h2',h.cta.title||'');setText('#cta-section p',h.cta.desc||'');const ca=document.querySelector('#cta-section .cta-actions');if(ca)ca.innerHTML=(h.cta.buttons||[]).filter(b=>b.show!==false).map((b,i)=>`<a href="${safeUrl(b.link)}" class="btn ${b.class||''}" ${i===0?'onclick="openModal()"':''}><i class="${(b.icon||'fa-check').startsWith('fab')?b.icon:'fas '+(b.icon||'fa-check')}"></i> ${b.text||''}</a>`).join('');}

const defaultServices = [
  {id:1, name:'تنظيف المنازل', icon:'fa-home', short:'تنظيف شامل وعميق لجميع غرف المنزل', status:'active'},

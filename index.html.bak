  {id:8, name:'تنظيف المطابخ', icon:'fa-blender', short:'تنظيف عميق للمطابخ والأجهزة', status:'active'},
  {id:9, name:'تنظيف الحمامات', icon:'fa-bath', short:'تعقيم وتطهير الحمامات كاملاً', status:'active'},
  {id:10, name:'تنظيف الخزانات', icon:'fa-water', short:'تنظيف وتعقيم خزانات المياه', status:'active'},
  {id:11, name:'تنظيف الزجاج', icon:'fa-window-maximize', short:'تنظيف الزجاج والواجهات', status:'active'},
  {id:12, name:'تنظيف بعد التشطيب', icon:'fa-hammer', short:'إزالة آثار الدهان والإنشاء', status:'active'},
  {id:13, name:'تنظيف المكاتب', icon:'fa-briefcase', short:'تنظيف الشركات والمكاتب', status:'active'},
  {id:14, name:'التعقيم والتطهير', icon:'fa-shield-virus', short:'تعقيم شامل ضد الجراثيم', status:'active'},
  {id:15, name:'تنظيف عميق', icon:'fa-spray-can', short:'تنظيف عميق متكامل', status:'active'},
  {id:16, name:'إزالة الروائح', icon:'fa-wind', short:'إزالة الروائح غير المرغوبة', status:'active'},
];

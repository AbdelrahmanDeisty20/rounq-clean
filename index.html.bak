// ===================== USERS =====================
function initUsers() {
  if(!DB.get('users')) {
    DB.set('users', [{
      id: 1, fullName: 'مدير النظام', username: 'admin',
      email: 'admin@alostora.com', phone: '0550000000',
      role: 'admin', password: 'Admin@12345',
      created: new Date().toLocaleDateString('ar-SA')
    }]);
  }
}

function toggleAddUserForm() {
  document.getElementById('editUserId').value='';
  ['uFullName','uUsername','uPassword','uEmail','uPhone'].forEach(id=>{const el=document.getElementById(id);if(el)el.value='';});
  document.getElementById('uRole').value='editor';
  document.getElementById('userModalTitle').textContent='إضافة مستخدم جديد';
  document.getElementById('userSaveLabel').textContent='إضافة المستخدم';
  document.getElementById('pwHint').textContent='(مطلوبة)';
  openAdminModal('userModal');
}

function renderUsersTable() {
  const tb = document.getElementById('usersTbody');
  if(!tb) return;
  const users = DB.get('users') || [];
  const roleLabels = { admin:'مدير', editor:'محرر', viewer:'مشاهد' };
  const roleBadge  = { admin:'status-done', editor:'status-progress', viewer:'status-new' };
  if(users.length === 0) {
    tb.innerHTML = '<tr><td colspan="7" style="text-align:center;padding:30px;color:var(--gray-500)">لا يوجد مستخدمون</td></tr>';
    return;
  }
  tb.innerHTML = users.map((u, i) => {
    const initial = (u.fullName||'م').charAt(0);
    const badge = roleBadge[u.role]||'status-new';
    const label = roleLabels[u.role]||u.role;
    const delBtn = u.username !== 'admin' ? '<button class="action-btn delete" onclick="deleteUser('+u.id+')" title="حذف"><i class="fas fa-trash"></i></button>' : '';
    return '<tr>' +
      '<td>'+(i+1)+'</td>' +
      '<td><div style="display:flex;align-items:center;gap:10px"><div style="width:36px;height:36px;min-width:36px;background:linear-gradient(135deg,var(--primary),var(--primary-light));border-radius:50%;display:flex;align-items:center;justify-content:center;color:white;font-weight:700;font-size:15px">'+initial+'</div><strong>'+(u.fullName||'بدون اسم')+'</strong></div></td>' +
      '<td><code style="background:var(--gray-100);padding:3px 10px;border-radius:6px;font-size:13px">'+u.username+'</code></td>' +
      '<td style="font-size:13px;color:var(--gray-700)">'+(u.email||'غير محدد')+'</td>' +
      '<td><span class="status-badge '+badge+'">'+label+'</span></td>' +
      '<td style="font-size:13px;color:var(--gray-500)">'+(u.created||'غير محدد')+'</td>' +
      '<td><div class="action-btns"><button class="action-btn edit" onclick="editUser('+u.id+')" title="تعديل"><i class="fas fa-edit"></i></button><button class="action-btn view" onclick="openPwModal('+u.id+')" title="تغيير كلمة المرور"><i class="fas fa-key"></i></button>'+delBtn+'</div></td>' +
      '</tr>';
  }).join('');
}

function saveUser() {
  const editId   = document.getElementById('editUserId').value;
  const fullName = document.getElementById('uFullName').value.trim();
  const username = document.getElementById('uUsername').value.trim();
  const password = document.getElementById('uPassword').value.trim();
  const role     = document.getElementById('uRole').value;
  const email    = document.getElementById('uEmail').value.trim();
  const phone    = document.getElementById('uPhone').value.trim();
  if(!fullName || !username){ showNotif('يرجى ادخال الاسم واسم المستخدم','error'); return; }
  const users = DB.get('users') || [];
  if(editId) {
    const id = parseInt(editId);
    const data = { fullName, username, role, email, phone };
    if(password) { if(password.length < 6){ showNotif('كلمة المرور يجب ان تكون 6 احرف على الاقل','error'); return; } data.password = password; }
    DB.update('users', id, data);
    showNotif('تم تحديث بيانات المستخدم بنجاح');
  } else {
    if(!password || password.length < 6){ showNotif('كلمة المرور يجب ان تكون 6 احرف على الاقل','error'); return; }
    if(users.find(u => u.username === username)){ showNotif('اسم المستخدم موجود مسبقا','error'); return; }
    DB.push('users', { fullName, username, password, role, email, phone, created: new Date().toLocaleDateString('ar-SA') });
    showNotif('تم اضافة المستخدم بنجاح');
  }
  closeAdminModal('userModal');
  renderUsersTable();
}

function editUser(id) {
  const u = (DB.get('users') || []).find(x => x.id === id);
  if(!u) return;
  document.getElementById('editUserId').value = id;
  document.getElementById('uFullName').value  = u.fullName || '';
  document.getElementById('uUsername').value  = u.username || '';
  document.getElementById('uPassword').value  = '';
  document.getElementById('uEmail').value     = u.email || '';
  document.getElementById('uPhone').value     = u.phone || '';
  document.getElementById('uRole').value      = u.role || 'editor';
  document.getElementById('userModalTitle').textContent = 'تعديل بيانات المستخدم';
  document.getElementById('userSaveLabel').textContent  = 'حفظ التعديلات';
  document.getElementById('pwHint').textContent = '(اتركها فارغة إذا لم ترد تغييرها)';
  openAdminModal('userModal');
}

function deleteUser(id) {
  const users = DB.get('users') || [];
  const u = users.find(x => x.id === id);
  if(u && u.username === 'admin'){ showNotif('لا يمكن حذف المدير الرئيسي','error'); return; }
  if(confirm('هل انت متاكد من حذف المستخدم؟')) {
    DB.remove('users', id);
    renderUsersTable();
    showNotif('تم حذف المستخدم');
  }
}

function openPwModal(id) {
  document.getElementById('pwUserId').value = id;
  document.getElementById('newPwInput').value = '';
  document.getElementById('confirmPwInput').value = '';
  openAdminModal('changePwModal');
}

function closePwModal() {
  closeAdminModal('changePwModal');
}

function confirmChangePassword() {
  const id  = parseInt(document.getElementById('pwUserId').value);
  const np  = document.getElementById('newPwInput').value;
  const cnp = document.getElementById('confirmPwInput').value;
  if(!np || np.length < 6){ showNotif('كلمة المرور يجب ان تكون 6 احرف على الاقل','error'); return; }
  if(np !== cnp){ showNotif('كلمتا المرور غير متطابقتين','error'); return; }
  DB.update('users', id, { password: np });
  const u = (DB.get('users') || []).find(x => x.id === id);
  if(u && u.username === 'admin') localStorage.setItem('alostora_admin_pass', np);
  closeAdminModal('changePwModal');
  showNotif('تم تغيير كلمة المرور بنجاح ✅');
}

// ===================== INIT =====================
window.addEventListener('DOMContentLoaded', ()=>{
  initData();
  initUsers();
  renderSite();

  // Load hero settings if saved
  const hs = DB.get('heroSettings');
  if(hs){
    ['heroStat1','heroStat2','heroStat3'].forEach((id,i)=>{const el=document.getElementById(id);if(el)el.textContent=[hs.stat1,hs.stat2,hs.stat3][i]||el.textContent;});
  }

  // Check auth
  if(window.location.hash==='#admin' || window.location.pathname==='/admin'){
    showAdmin({preventDefault:()=>{}});
  }
});

// Scroll header effect
window.addEventListener('scroll',()=>{
  const h=document.getElementById('siteHeader');
  if(h){h.style.boxShadow=window.scrollY>50?'0 4px 30px rgba(26,58,107,0.15)':'var(--shadow)';}
});
</script>


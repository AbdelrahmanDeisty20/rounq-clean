const defaultTestimonials = [
  {id:1, name:'أحمد العبدالله', city:'بريدة', rating:5, service:'تنظيف فيلا', text:'خدمة ممتازة ورائعة، الفريق محترف ومنظم، والنتيجة فاقت توقعاتي. أنصح بهم بشدة لكل من يريد تنظيفاً حقيقياً لمنزله.', status:'active'},
  {id:2, name:'منيرة السهلي', city:'عنيزة', rating:5, service:'تنظيف كنب وسجاد', text:'أفضل شركة تنظيف تعاملت معها في القصيم. الكنب خرج جديداً تماماً والسجاد لمع كأنه جديد. سأتعامل معهم دائماً.', status:'active'},
  {id:3, name:'خالد الرشيد', city:'الرس', rating:5, service:'تنظيف بعد تشطيب', text:'أنجزوا تنظيف بعد التشطيب في وقت قياسي وبجودة عالية جداً. فعلاً فريق محترف يعرف شغله جيداً.', status:'active'},
];
const defaultFaqs = [
  {id:1, q:'كم تستغرق خدمة تنظيف المنزل؟', a:'تتراوح مدة الخدمة بين 3-8 ساعات حسب حجم المنزل ونوع الخدمة المطلوبة. نحرص على إنجاز العمل بدقة دون التهاون في الجودة.'},
  {id:2, q:'هل المواد المستخدمة آمنة للأطفال والحيوانات الأليفة؟', a:'نعم، نستخدم فقط منظفات آمنة ومعتمدة صديقة للبيئة وآمنة تماماً للأطفال والحيوانات الأليفة ولا تسبب أي أضرار.'},
  {id:3, q:'هل تقدمون ضمان على جودة الخدمة؟', a:'نعم، نوفر ضمان الرضا الكامل. إذا لم تكن راضياً عن جودة العمل، سيعود فريقنا لإعادة الخدمة مجاناً خلال 24 ساعة.'},
  {id:4, q:'ما هي مناطق تغطية الخدمة؟', a:'نخدم جميع أنحاء منطقة القصيم: بريدة، عنيزة، الرس، البكيرية، المذنب، البدائع، رياض الخبراء، عيون الجواء، والشماسية.'},
  {id:5, q:'كيف يمكنني طلب الخدمة؟', a:'يمكنك طلب الخدمة عبر: الاتصال بنا مباشرة، التواصل عبر واتساب، أو تعبئة نموذج الطلب في موقعنا. نرد على جميع الطلبات في نفس اليوم.'},
];
const defaultBlogs = [
  {id:1, title:'أفضل 10 نصائح لتنظيف المنزل بسرعة وفاعلية', cat:'نصائح التنظيف', summary:'تعرف على أسرار التنظيف السريع التي يستخدمها المحترفون', status:'published', date:'2025-01-15'},
  {id:2, title:'كيف تنظف الكنب والمجالس في المنزل بطريقة صحيحة', cat:'تنظيف الكنب', summary:'دليل شامل لتنظيف الكنب والمجالس والتخلص من البقع', status:'published', date:'2025-01-10'},
  {id:3, title:'دليل التعقيم الشامل للمنزل وأهمية التطهير الدوري', cat:'التعقيم والتطهير', summary:'لماذا يحتاج منزلك إلى تعقيم منتظم وكيف نساعدك', status:'published', date:'2025-01-05'},
];

function initData() {
  if(!DB.get('services')) DB.set('services', defaultServices);
  if(!DB.get('offers')) DB.set('offers', defaultOffers);
  if(!DB.get('testimonials')) DB.set('testimonials', defaultTestimonials);
  if(!DB.get('faqs')) DB.set('faqs', defaultFaqs);
  if(!DB.get('blogs')) DB.set('blogs', defaultBlogs);
  if(!DB.get('requests')) DB.set('requests', []);
  if(!DB.get('messages')) DB.set('messages', []);
  if(!DB.get('clicks')) DB.set('clicks', []);
  if(!DB.get('homeSettings')) DB.set('homeSettings', cloneHomeDefaults());
  if(!DB.get('contactSettings')) DB.set('contactSettings', {
    phone1:'0550000000', wa:'966550000000', email1:'info@alostora.com',
    address:'بريدة، منطقة القصيم', hours:'السبت - الخميس: 7ص - 10م',
    waMsg:'السلام عليكم، أود الاستفسار عن خدمات التنظيف'
  });
}

// ===================== SITE RENDERING =====================
function renderSite() {
  // Services
  const services = DB.get('services')||[];
  const sg = document.getElementById('servicesGrid');
  if(sg) sg.innerHTML = services.filter(s=>s.status==='active').map(s=>`
    <div class="service-card" onclick="openModal()">
      <div class="svc-icon"><i class="fas ${s.icon||'fa-broom'}"></i></div>
      <h3>${s.name}</h3>
      <p>${s.short||''}</p>
    </div>`).join('');

  // Offers
  const offers = DB.get('offers')||[];
  const og = document.getElementById('offersGrid');
  if(og) og.innerHTML = offers.filter(o=>o.status==='active').map((o,i)=>`
    <div class="offer-card ${i===1?'featured':''}">
      ${i===1?'<span class="offer-badge">الأكثر طلباً</span>':''}
      <div class="offer-header">
        <h3>${o.name}</h3>
        <p style="font-size:13px;color:rgba(255,255,255,0.75);margin-top:6px">شامل الضريبة</p>
        <div class="offer-price">
          <span class="old">${o.oldPrice} ر.س</span>
          <span class="new">${o.newPrice}</span>
          <span class="unit">ر.س</span>
        </div>
      </div>
      <div class="offer-body">
        <ul class="offer-features">
          ${(o.features||'').split('\n').filter(f=>f.trim()).map(f=>`<li><i class="fas fa-check-circle"></i>${f}</li>`).join('')}
        </ul>
        <a href="#" class="btn btn-primary" onclick="openModal()"><i class="fas fa-calendar-check"></i> اطلب هذه الباقة</a>
      </div>
    </div>`).join('');

  // Testimonials
  const tests = DB.get('testimonials')||[];
  const tg = document.getElementById('testimonialsGrid');
  if(tg) tg.innerHTML = tests.filter(t=>t.status==='active').map(t=>`
    <div class="testimonial-card">
      <div class="stars">${'⭐'.repeat(t.rating||5)}</div>
      <p>${t.text}</p>
      <div class="testimonial-author">
        <div class="author-avatar">${t.name.charAt(0)}</div>
        <div class="author-info"><strong>${t.name}</strong><span>${t.city} | ${t.service}</span></div>
      </div>
    </div>`).join('');

  // FAQs
  const faqs = DB.get('faqs')||[];
  const fl = document.getElementById('faqList');
  if(fl) fl.innerHTML = faqs.map((f,i)=>`
    <div class="faq-item" id="faq_${f.id}">
      <div class="faq-q" onclick="toggleFaq('faq_${f.id}')">
        <span>${f.q}</span><i class="fas fa-chevron-down"></i>
      </div>
      <div class="faq-a"><p>${f.a}</p></div>
    </div>`).join('');

  // Blog
  const blogs = DB.get('blogs')||[];
  const bg = document.getElementById('blogGrid');
  if(bg) bg.innerHTML = blogs.filter(b=>b.status==='published').slice(0,3).map(b=>`
    <div class="blog-card">
      <div class="blog-thumb ${b.image?'':'img-placeholder'}">${b.image?`<img src="${b.image}" alt="${b.title}">`:'<i class="fas fa-blog"></i>'}</div>
      <div class="blog-body">
        <span class="blog-cat">${b.cat}</span>
        <h3>${b.title}</h3>
        <p>${b.summary}</p>
        <div class="blog-meta"><span><i class="fas fa-calendar"></i> ${b.date||''}</span><span><i class="fas fa-clock"></i> 5 دقائق</span></div>
      </div>
    </div>`).join('');

  // Contact settings
  const cs = DB.get('contactSettings')||{};
  const cp = document.getElementById('contactPhone'); if(cp) cp.textContent=cs.phone1||'0550000000';
  const cw = document.getElementById('contactWa'); if(cw) cw.textContent=cs.phone1||'0550000000';
  const ce = document.getElementById('contactEmail'); if(ce) ce.textContent=cs.email1||'info@alostora.com';
  const ca = document.getElementById('contactAddress'); if(ca) ca.textContent=cs.address||'بريدة، منطقة القصيم';
  const ch = document.getElementById('contactHours'); if(ch) ch.textContent=cs.hours||'السبت - الخميس: 7ص - 10م';

  // WA links
  const waNum = cs.wa||'966550000000';
  const waMsg = encodeURIComponent(cs.waMsg||'السلام عليكم');
  const waUrl = `https://wa.me/${waNum}?text=${waMsg}`;
  [document.getElementById('headerWaBtn'), document.getElementById('floatWa')].forEach(el=>{if(el){el.href=waUrl;}});
  renderManagedHome();
}

// ===================== FAQ TOGGLE =====================
function toggleFaq(id) {
  const item = document.getElementById(id);
  if(item) { item.classList.toggle('active'); }
}

// ===================== MODAL =====================
function openModal() { document.getElementById('requestModal').classList.add('open'); }
function closeModal() { document.getElementById('requestModal').classList.remove('open'); }
document.getElementById('requestModal').addEventListener('click', function(e) { if(e.target===this) closeModal(); });

// ===================== FORMS =====================
function submitRequest() {
  const name = document.getElementById('reqName').value.trim();
  const phone = document.getElementById('reqPhone').value.trim();
  const city = document.getElementById('reqCity').value;
  const service = document.getElementById('reqService').value;
  if(!name||!phone||!city||!service) { showNotif('يرجى تعبئة جميع الحقول المطلوبة','error'); return; }
  DB.push('requests', {name, phone, city, service, date:document.getElementById('reqDate').value, notes:document.getElementById('reqNotes').value, status:'new', created:new Date().toLocaleString('ar')});
  closeModal();
  showNotif('تم إرسال طلبك بنجاح، سنتواصل معك قريباً ✅');
  ['reqName','reqPhone','reqDate','reqNotes'].forEach(id=>{ const el=document.getElementById(id); if(el)el.value=''; });
  ['reqCity','reqService'].forEach(id=>{ const el=document.getElementById(id); if(el)el.selectedIndex=0; });
  updateAdminCounts();
}

function submitContact() {
  showNotif('تم إرسال رسالتك بنجاح، سنرد عليك قريباً ✅');
}

// ===================== CLICK TRACKING =====================
function trackClick(type, page) {
  DB.push('clicks', {type, page, time: new Date().toLocaleString('ar')});
  updateAdminCounts();
}

// ===================== MOBILE NAV =====================
function toggleMobile() {
  document.getElementById('mobileNav').classList.toggle('open');
}

// ===================== NOTIFICATION =====================
function showNotif(msg, type='success') {
  const n = document.getElementById('notification');
  document.getElementById('notifText').textContent = msg;
  n.className = 'notification show' + (type==='error'?' error':'');
  setTimeout(()=>n.classList.remove('show'), 3500);
}

// ===================== AUTH =====================
function doLogin() {
  const u = document.getElementById('loginUser').value;
  const p = document.getElementById('loginPass').value;
  const stored = localStorage.getItem('alostora_admin_pass')||'Admin@12345';
  if(u==='admin' && p===stored) {
    sessionStorage.setItem('alostora_auth','1');
    document.getElementById('adminLogin').classList.add('hidden');
    document.getElementById('adminWrap').classList.add('active');
    document.getElementById('siteWrap').classList.add('hidden');
    document.getElementById('loginError').classList.remove('show');
    renderAdminPanels();
    updateAdminCounts();
    document.getElementById('lastLogin').textContent = new Date().toLocaleString('ar');
  } else {
    document.getElementById('loginError').classList.add('show');
  }
}

function doLogout() {
  sessionStorage.removeItem('alostora_auth');
  document.getElementById('adminWrap').classList.remove('active');
  document.getElementById('siteWrap').classList.remove('hidden');
  document.getElementById('adminLogin').classList.remove('hidden');
}

function goToSite() {
  document.getElementById('adminWrap').classList.remove('active');
  document.getElementById('siteWrap').classList.remove('hidden');
  document.getElementById('adminLogin').classList.add('hidden');
}

function showAdmin(e) {
  e.preventDefault();
  if(sessionStorage.getItem('alostora_auth')==='1') {
    document.getElementById('siteWrap').classList.add('hidden');
    document.getElementById('adminWrap').classList.add('active');
    document.getElementById('adminLogin').classList.add('hidden');
    renderAdminPanels();
    updateAdminCounts();
  } else {
    document.getElementById('siteWrap').classList.add('hidden');
    document.getElementById('adminLogin').classList.remove('hidden');
  }
}

function changePass() {
  const np = prompt('أدخل كلمة المرور الجديدة:');
  if(np && np.length>=6) { localStorage.setItem('alostora_admin_pass', np); showNotif('تم تغيير كلمة المرور بنجاح'); }
  else if(np) { showNotif('يجب أن تكون كلمة المرور 6 أحرف على الأقل','error'); }
}

// ===================== ADMIN PANELS =====================
function showPanel(id, el) {
  document.querySelectorAll('.admin-panel').forEach(p=>p.classList.remove('active'));
  const panel = document.getElementById(id);
  if(panel) panel.classList.add('active');
  document.querySelectorAll('.admin-nav a').forEach(a=>a.classList.remove('active'));
  if(el) el.classList.add('active');
  const titles = {
    'dashboard':'لوحة التحكم الرئيسية','home-manager-panel':'إدارة الصفحة الرئيسية','contact-settings':'إعدادات التواصل','hero-settings':'إعدادات البانر',
    'services-panel':'إدارة الخدمات','offers-panel':'إدارة العروض والباقات','testimonials-panel':'إدارة آراء العملاء',
    'faq-panel':'الأسئلة الشائعة','gallery-panel':'معرض الصور','blog-panel':'إدارة المقالات',
    'requests-panel':'طلبات الخدمة','messages-panel':'رسائل التواصل','seo-settings':'إعدادات SEO',
    'users-panel':'إدارة المستخدمين','analytics-panel':'الإحصائيات والتتبع'
  };
  document.getElementById('adminPageTitle').textContent = titles[id]||'لوحة التحكم';
  renderAdminPanels();
}

function renderAdminPanels() {
  renderServicesTable();
  renderOffersTable();
  renderTestimonialsTable();
  renderFaqTable();
  renderBlogTable();
  renderRequestsTable();
  renderMessagesTable();
  renderClickLog();
  renderUsersTable();
  loadContactSettings();
  loadHomeManager();
  updateAdminCounts();
}

function updateAdminCounts() {
  const reqs = (DB.get('requests')||[]).length;
  const msgs = (DB.get('messages')||[]).length;
  const clicks = DB.get('clicks')||[];
  const waC = clicks.filter(c=>c.type==='whatsapp').length;
  const phC = clicks.filter(c=>c.type==='phone').length;
  const total = clicks.length;
  ['statReqs','reqCount'].forEach(id=>{const el=document.getElementById(id);if(el)el.textContent=reqs;});
  ['statMsgs','msgCount'].forEach(id=>{const el=document.getElementById(id);if(el)el.textContent=msgs;});
  ['statClicks','totalClicks2'].forEach(id=>{const el=document.getElementById(id);if(el)el.textContent=total;});
  ['waClicks','waClicksA'].forEach(id=>{const el=document.getElementById(id);if(el)el.textContent=waC;});
  ['phoneClicks','phoneClicksA'].forEach(id=>{const el=document.getElementById(id);if(el)el.textContent=phC;});

  // Latest
  const reqsAll = DB.get('requests')||[];
  const lr = document.getElementById('latestReqs');
  if(lr) {
    if(reqsAll.length===0) { lr.innerHTML='<div style="text-align:center;padding:30px;color:var(--gray-500)">لا توجد طلبات بعد</div>'; }
    else {
      lr.innerHTML = `<table class="admin-table"><thead><tr><th>الاسم</th><th>الخدمة</th><th>الحالة</th></tr></thead><tbody>
        ${reqsAll.slice(-5).reverse().map(r=>`<tr><td>${r.name}</td><td>${r.service}</td><td><span class="status-badge status-${r.status||'new'}">${statusLabel(r.status)}</span></td></tr>`).join('')}
      </tbody></table>`;
    }
  }
}

function statusLabel(s) {
  return {new:'جديد',progress:'قيد التواصل',done:'مكتمل',cancel:'ملغي'}[s]||'جديد';
}

// --- Services ---
// ===================== MODAL HELPERS =====================
function openAdminModal(id) {
  document.getElementById(id).classList.add('open');
  document.getElementById(id).addEventListener('click', function(e){ if(e.target===this) closeAdminModal(id); }, {once:true});
}
function closeAdminModal(id) {
  document.getElementById(id).classList.remove('open');
}

// ===================== SERVICES =====================
function renderServicesTable() {
  const tb = document.getElementById('servicesTbody'); if(!tb) return;
  const services = DB.get('services')||[];
  tb.innerHTML = services.map((s,i)=>`
    <tr>
      <td>${i+1}</td>
      <td><i class="fas ${s.icon||'fa-broom'}" style="color:var(--primary);margin-left:6px"></i> ${s.name}</td>
      <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${s.short||''}</td>
      <td><span class="status-badge ${s.status==='active'?'status-done':'status-cancel'}">${s.status==='active'?'نشط':'مخفي'}</span></td>
      <td><div class="action-btns">
        <button class="action-btn edit" onclick="editService(${s.id})" title="تعديل"><i class="fas fa-edit"></i></button>
        <button class="action-btn delete" onclick="deleteService(${s.id})" title="حذف"><i class="fas fa-trash"></i></button>
      </div></td>
    </tr>`).join('');
}
function showAddService() {
  document.getElementById('editSvcId').value='';
  ['svcName','svcShortDesc','svcDesc','svcMeta'].forEach(id=>{const el=document.getElementById(id);if(el)el.value='';});
  document.getElementById('svcIcon').value='fa-home';
  document.getElementById('iconPreview').className='fas fa-home';
  document.getElementById('svcStatus').value='active';
  document.getElementById('svcModalTitle').textContent='إضافة خدمة جديدة';
  openAdminModal('svcModal');
}
function editService(id) {
  const svc = (DB.get('services')||[]).find(s=>s.id===id);
  if(!svc) return;
  document.getElementById('editSvcId').value=id;
  document.getElementById('svcName').value=svc.name||'';
  const icon=svc.icon||'fa-broom';
  document.getElementById('svcIcon').value=icon;
  document.getElementById('iconPreview').className='fas '+icon;
  document.getElementById('svcShortDesc').value=svc.short||'';
  document.getElementById('svcDesc').value=svc.desc||'';
  document.getElementById('svcMeta').value=svc.meta||'';
  document.getElementById('svcStatus').value=svc.status||'active';
  document.getElementById('svcModalTitle').textContent='تعديل الخدمة';
  openAdminModal('svcModal');
}
function saveService() {
  const id = document.getElementById('editSvcId').value;
  const data = {name:document.getElementById('svcName').value, icon:'fa-'+document.getElementById('svcIcon').value.replace('fa-',''), short:document.getElementById('svcShortDesc').value, desc:document.getElementById('svcDesc').value, meta:document.getElementById('svcMeta').value, status:document.getElementById('svcStatus').value};
  if(!data.name){showNotif('يرجى إدخال اسم الخدمة','error');return;}
  if(id) { DB.update('services',parseInt(id),data); } else { DB.push('services',data); }
  renderServicesTable(); renderSite(); closeAdminModal('svcModal');
  showNotif('تم حفظ الخدمة بنجاح ✅');
}
function deleteService(id) {
  if(confirm('هل أنت متأكد من حذف هذه الخدمة؟')) { DB.remove('services',id); renderServicesTable(); renderSite(); showNotif('تم حذف الخدمة'); }
}

// --- Offers ---
function renderOffersTable() {
  const tb = document.getElementById('offersTbody'); if(!tb) return;
  const offers = DB.get('offers')||[];
  tb.innerHTML = offers.map((o,i)=>`
    <tr>
      <td>${i+1}</td><td>${o.name}</td>
      <td style="text-decoration:line-through;color:var(--gray-500)">${o.oldPrice} ر.س</td>
      <td style="color:var(--green);font-weight:700">${o.newPrice} ر.س</td>
      <td><span class="status-badge ${o.status==='active'?'status-done':'status-cancel'}">${o.status==='active'?'نشط':'مخفي'}</span></td>
      <td><div class="action-btns">
        <button class="action-btn edit" onclick="editOffer(${o.id})"><i class="fas fa-edit"></i></button>
        <button class="action-btn delete" onclick="deleteOffer(${o.id})"><i class="fas fa-trash"></i></button>
      </div></td>
    </tr>`).join('');
}
function showAddOffer(){
  document.getElementById('editOfferId').value='';
  ['offerName','offerOld','offerNew','offerFeatures'].forEach(id=>{const el=document.getElementById(id);if(el)el.value='';}); window._offerImage=''; const op=document.getElementById('offerImagePreview'); if(op){op.style.display='none';op.src='';}
  document.getElementById('offerStatus').value='active';
  document.getElementById('offerModalTitle').textContent='إضافة عرض جديد';
  openAdminModal('offerModal');
}
function editOffer(id){
  const o=(DB.get('offers')||[]).find(x=>x.id===id); if(!o)return;
  document.getElementById('editOfferId').value=id;
  document.getElementById('offerName').value=o.name||'';
  document.getElementById('offerOld').value=o.oldPrice||'';
  document.getElementById('offerNew').value=o.newPrice||'';
  document.getElementById('offerFeatures').value=o.features||''; window._offerImage=o.image||''; const op=document.getElementById('offerImagePreview'); if(op){op.style.display=o.image?'block':'none';op.src=o.image||'';}
  document.getElementById('offerStatus').value=o.status||'active';
  document.getElementById('offerModalTitle').textContent='تعديل العرض';
  openAdminModal('offerModal');
}
function saveOffer(){
  const editId=document.getElementById('editOfferId')?.value;
  const data={name:document.getElementById('offerName').value,oldPrice:document.getElementById('offerOld').value,newPrice:document.getElementById('offerNew').value,features:document.getElementById('offerFeatures').value,status:document.getElementById('offerStatus').value,image:window._offerImage||''};
  if(!data.name){showNotif('يرجى إدخال اسم الباقة','error');return;}
  if(editId){DB.update('offers',parseInt(editId),data);}else{DB.push('offers',data);}
  renderOffersTable(); renderSite(); closeAdminModal('offerModal'); showNotif('تم حفظ العرض بنجاح ✅');
}
function deleteOffer(id){if(confirm('حذف هذا العرض؟')){DB.remove('offers',id);renderOffersTable();renderSite();showNotif('تم الحذف');}}

// --- Testimonials ---
function renderTestimonialsTable(){
  const tb=document.getElementById('testimonialsTbody');if(!tb)return;
  const tests=DB.get('testimonials')||[];
  tb.innerHTML=tests.map((t,i)=>`<tr><td>${i+1}</td><td>${t.name}</td><td>${'⭐'.repeat(t.rating||5)}</td><td>${t.city}</td>
    <td><span class="status-badge ${t.status==='active'?'status-done':'status-cancel'}">${t.status==='active'?'نشط':'مخفي'}</span></td>
    <td><div class="action-btns"><button class="action-btn edit" onclick="editTest(${t.id})"><i class="fas fa-edit"></i></button><button class="action-btn delete" onclick="deleteTest(${t.id})"><i class="fas fa-trash"></i></button></div></td></tr>`).join('');
}
function showAddTestimonial(){
  document.getElementById('editTestId').value='';
  ['testName','testCity','testService','testText'].forEach(id=>{const el=document.getElementById(id);if(el)el.value='';});
  document.getElementById('testRating').value='5';
  document.getElementById('testModalTitle').textContent='إضافة رأي عميل';
  openAdminModal('testModal');
}
function saveTestimonial(){
  const data={name:document.getElementById('testName').value,city:document.getElementById('testCity').value,rating:parseInt(document.getElementById('testRating').value),service:document.getElementById('testService').value,text:document.getElementById('testText').value,status:'active'};
  if(!data.name||!data.text){showNotif('يرجى تعبئة الحقول المطلوبة','error');return;}
  const eid=document.getElementById('editTestId')?.value;
  if(eid){DB.update('testimonials',parseInt(eid),data);}else{DB.push('testimonials',data);}
  renderTestimonialsTable();renderSite();closeAdminModal('testModal');showNotif('تم حفظ الرأي بنجاح ✅');
}
function editTest(id){
  const t=(DB.get('testimonials')||[]).find(x=>x.id===id); if(!t)return;
  document.getElementById('editTestId').value=id;
  document.getElementById('testName').value=t.name||'';
  document.getElementById('testCity').value=t.city||'';
  document.getElementById('testRating').value=t.rating||5;
  document.getElementById('testService').value=t.service||'';
  document.getElementById('testText').value=t.text||'';
  document.getElementById('testModalTitle').textContent='تعديل رأي العميل';
  openAdminModal('testModal');
}
function deleteTest(id){if(confirm('حذف هذا الرأي؟')){DB.remove('testimonials',id);renderTestimonialsTable();renderSite();showNotif('تم الحذف');}}

// --- FAQs ---
function renderFaqTable(){
  const tb=document.getElementById('faqTbody');if(!tb)return;
  const faqs=DB.get('faqs')||[];
  tb.innerHTML=faqs.map((f,i)=>`<tr><td>${i+1}</td><td>${f.q}</td><td>عام</td>
    <td><div class="action-btns"><button class="action-btn edit" onclick="editFaq(${f.id})"><i class="fas fa-edit"></i></button><button class="action-btn delete" onclick="deleteFaq(${f.id})"><i class="fas fa-trash"></i></button></div></td></tr>`).join('');
}
function showAddFaq(){
  document.getElementById('editFaqId').value='';
  document.getElementById('faqQ').value='';
  document.getElementById('faqA').value='';
  document.getElementById('faqModalTitle').textContent='إضافة سؤال جديد';
  openAdminModal('faqModal');
}
function saveFaq(){
  const data={q:document.getElementById('faqQ').value,a:document.getElementById('faqA').value};
  if(!data.q||!data.a){showNotif('يرجى تعبئة السؤال والإجابة','error');return;}
  const eid=document.getElementById('editFaqId')?.value;
  if(eid){DB.update('faqs',parseInt(eid),data);}else{DB.push('faqs',data);}
  renderFaqTable();renderSite();closeAdminModal('faqModal');showNotif('تم حفظ السؤال ✅');
}
function editFaq(id){
  const f=(DB.get('faqs')||[]).find(x=>x.id===id); if(!f)return;
  document.getElementById('editFaqId').value=id;
  document.getElementById('faqQ').value=f.q||'';
  document.getElementById('faqA').value=f.a||'';
  document.getElementById('faqModalTitle').textContent='تعديل السؤال';
  openAdminModal('faqModal');
}
function deleteFaq(id){if(confirm('حذف هذا السؤال؟')){DB.remove('faqs',id);renderFaqTable();renderSite();showNotif('تم الحذف');}}

// --- Blog ---
function renderBlogTable(){
  const tb=document.getElementById('blogTbody');if(!tb)return;
  const blogs=DB.get('blogs')||[];
  tb.innerHTML=blogs.map((b,i)=>`<tr><td>${i+1}</td><td>${b.title}</td><td>${b.cat}</td>
    <td><span class="status-badge ${b.status==='published'?'status-done':'status-progress'}">${b.status==='published'?'منشور':'مسودة'}</span></td>
    <td><div class="action-btns"><button class="action-btn edit" onclick="editBlog(${b.id})"><i class="fas fa-edit"></i></button><button class="action-btn delete" onclick="deleteBlog(${b.id})"><i class="fas fa-trash"></i></button></div></td></tr>`).join('');
}
function showAddBlog(){
  document.getElementById('editBlogId').value='';
  ['blogTitle','blogCat','blogSummary','blogContent','blogMeta'].forEach(id=>{const el=document.getElementById(id);if(el)el.value='';}); window._blogImage=''; const bp=document.getElementById('blogImagePreview'); if(bp){bp.style.display='none';bp.src='';}
  document.getElementById('blogStatus').value='published';
  document.getElementById('blogModalTitle').textContent='إضافة مقال جديد';
  openAdminModal('blogModal');
}
function saveBlog(){
  const data={title:document.getElementById('blogTitle').value,cat:document.getElementById('blogCat').value,summary:document.getElementById('blogSummary').value,content:document.getElementById('blogContent').value,meta:document.getElementById('blogMeta').value,status:document.getElementById('blogStatus').value,image:window._blogImage||'',date:new Date().toLocaleDateString('ar')};
  if(!data.title){showNotif('يرجى إدخال عنوان المقال','error');return;}
  const eid=document.getElementById('editBlogId')?.value;
  if(eid){DB.update('blogs',parseInt(eid),data);}else{DB.push('blogs',data);}
  renderBlogTable();renderSite();closeAdminModal('blogModal');showNotif('تم نشر المقال بنجاح ✅');
}
function editBlog(id){
  const b=(DB.get('blogs')||[]).find(x=>x.id===id); if(!b)return;
  document.getElementById('editBlogId').value=id;
  document.getElementById('blogTitle').value=b.title||'';
  document.getElementById('blogCat').value=b.cat||'';
  document.getElementById('blogSummary').value=b.summary||'';
  document.getElementById('blogContent').value=b.content||'';
  document.getElementById('blogMeta').value=b.meta||''; window._blogImage=b.image||''; const bp=document.getElementById('blogImagePreview'); if(bp){bp.style.display=b.image?'block':'none';bp.src=b.image||'';}
  document.getElementById('blogStatus').value=b.status||'published';
  document.getElementById('blogModalTitle').textContent='تعديل المقال';
  openAdminModal('blogModal');
}
function deleteBlog(id){if(confirm('حذف هذا المقال؟')){DB.remove('blogs',id);renderBlogTable();renderSite();showNotif('تم الحذف');}}

// --- Requests ---
function renderRequestsTable(){
  const tb=document.getElementById('requestsTbody');if(!tb)return;
  let reqs=DB.get('requests')||[];
  const fs=document.getElementById('filterStatus');
  const fc=document.getElementById('filterCity');
  if(fs&&fs.value) reqs=reqs.filter(r=>r.status===fs.value);
  if(fc&&fc.value) reqs=reqs.filter(r=>r.city===fc.value);
  tb.innerHTML=reqs.length===0?'<tr><td colspan="8" style="text-align:center;padding:30px;color:var(--gray-500)">لا توجد طلبات بعد</td></tr>':
    reqs.reverse().map((r,i)=>`<tr>
      <td>${i+1}</td><td>${r.name}</td><td>${r.phone}</td><td>${r.city}</td><td>${r.service}</td><td>${r.date||r.created}</td>
      <td><select style="padding:4px 8px;border-radius:6px;font-family:var(--font-main);font-size:12px;border:1.5px solid var(--gray-200)" onchange="updateReqStatus(${r.id},this.value)">
        <option value="new" ${r.status==='new'?'selected':''}>جديد</option>
        <option value="progress" ${r.status==='progress'?'selected':''}>قيد التواصل</option>
        <option value="done" ${r.status==='done'?'selected':''}>مكتمل</option>
        <option value="cancel" ${r.status==='cancel'?'selected':''}>ملغي</option>
      </select></td>
      <td><div class="action-btns">
        <button class="action-btn view" onclick="viewReq(${r.id})" title="عرض"><i class="fas fa-eye"></i></button>
        <button class="action-btn delete" onclick="deleteReq(${r.id})" title="حذف"><i class="fas fa-trash"></i></button>
      </div></td>
    </tr>`).join('');
}
function filterRequests(){renderRequestsTable();}
function updateReqStatus(id,status){DB.update('requests',id,{status});showNotif('تم تحديث الحالة');}
function deleteReq(id){if(confirm('حذف هذا الطلب؟')){DB.remove('requests',id);renderRequestsTable();updateAdminCounts();showNotif('تم الحذف');}}
function viewReq(id){const r=(DB.get('requests')||[]).find(x=>x.id===id);if(r)alert(`الاسم: ${r.name}\nالجوال: ${r.phone}\nالمدينة: ${r.city}\nالخدمة: ${r.service}\nالتاريخ: ${r.date}\nالملاحظات: ${r.notes||'لا توجد'}`);}
function exportCSV(){
  const reqs=DB.get('requests')||[];
  const csv=['الاسم,الجوال,المدينة,الخدمة,التاريخ,الحالة',...reqs.map(r=>`${r.name},${r.phone},${r.city},${r.service},${r.date||''},${statusLabel(r.status)}`)].join('\n');
  const blob=new Blob(['\ufeff'+csv],{type:'text/csv;charset=utf-8'});
  const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='requests.csv';a.click();
}

// --- Messages ---
function renderMessagesTable(){
  const tb=document.getElementById('messagesTbody');if(!tb)return;
  const msgs=DB.get('messages')||[];
  tb.innerHTML=msgs.length===0?'<tr><td colspan="7" style="text-align:center;padding:30px;color:var(--gray-500)">لا توجد رسائل بعد</td></tr>':
    msgs.reverse().map((m,i)=>`<tr><td>${i+1}</td><td>${m.name}</td><td>${m.phone}</td><td>${m.subject}</td><td>${m.date}</td>
      <td><span class="status-badge ${m.replied?'status-done':'status-new'}">${m.replied?'تم الرد':'جديدة'}</span></td>
      <td><div class="action-btns"><button class="action-btn delete" onclick="deleteMsg(${m.id})"><i class="fas fa-trash"></i></button></div></td></tr>`).join('');
}
function deleteMsg(id){if(confirm('حذف هذه الرسالة؟')){DB.remove('messages',id);renderMessagesTable();updateAdminCounts();showNotif('تم الحذف');}}

// --- Click Log ---
function renderClickLog(){
  const tb=document.getElementById('clickLog');if(!tb)return;
  const clicks=(DB.get('clicks')||[]).slice(-20).reverse();
  tb.innerHTML=clicks.length===0?'<tr><td colspan="3" style="text-align:center;padding:20px;color:var(--gray-500)">لا توجد نقرات بعد</td></tr>':
    clicks.map(c=>`<tr><td><span class="status-badge ${c.type==='whatsapp'?'status-done':'status-new'}">${c.type==='whatsapp'?'واتساب':'هاتف'}</span></td><td>${c.page}</td><td>${c.time}</td></tr>`).join('');
}

// --- Contact Settings ---
function loadContactSettings(){
  const cs=DB.get('contactSettings')||{};
  const fields={cs_phone1:'phone1',cs_phone2:'phone2',cs_wa:'wa',cs_waMsg:'waMsg',cs_email1:'email1',cs_email2:'email2',cs_address:'address',cs_map:'map',cs_hours:'hours',cs_fb:'facebook',cs_ig:'instagram',cs_tw:'twitter',cs_tt:'tiktok',cs_snap:'snapchat',cs_yt:'youtube'};
  Object.entries(fields).forEach(([elId,key])=>{const el=document.getElementById(elId);if(el)el.value=cs[key]||'';});
}
function saveContactSettings(){
  const data={phone1:document.getElementById('cs_phone1').value,phone2:document.getElementById('cs_phone2').value,wa:document.getElementById('cs_wa').value,waMsg:document.getElementById('cs_waMsg').value,email1:document.getElementById('cs_email1').value,email2:document.getElementById('cs_email2').value,address:document.getElementById('cs_address').value,map:document.getElementById('cs_map').value,hours:document.getElementById('cs_hours').value,facebook:document.getElementById('cs_fb').value,instagram:document.getElementById('cs_ig').value,twitter:document.getElementById('cs_tw').value,tiktok:document.getElementById('cs_tt').value,snapchat:document.getElementById('cs_snap').value,youtube:document.getElementById('cs_yt').value};
  DB.set('contactSettings',data);renderSite();showNotif('تم حفظ إعدادات التواصل وتطبيقها على الموقع ✅');
}


function readAdminImage(file,cb){if(!file)return;if(!file.type.startsWith('image/')){showNotif('الملف يجب أن يكون صورة فقط','error');return;}if(file.size>5*1024*1024){showNotif('حجم الصورة أكبر من 5MB','error');return;}const r=new FileReader();r.onload=()=>cb(r.result);r.readAsDataURL(file);}
function uploadOfferImage(e){readAdminImage(e.target.files[0],data=>{window._offerImage=data;const p=document.getElementById('offerImagePreview');if(p){p.src=data;p.style.display='block';}showNotif('تم رفع صورة العرض');});}
function uploadBlogImage(e){readAdminImage(e.target.files[0],data=>{window._blogImage=data;const p=document.getElementById('blogImagePreview');if(p){p.src=data;p.style.display='block';}showNotif('تم رفع صورة المقال');});}
// --- Home Page Manager ---
function setInput(id,val){const el=document.getElementById(id);if(el)el.value=val??'';}function getInput(id){const el=document.getElementById(id);return el?el.value:'';}
function loadHomeManager(){const h=getHomeSettings();setInput('hm_hero_badge',h.hero.badge);setInput('hm_hero_title',h.hero.title);setInput('hm_hero_desc',h.hero.desc);setInput('hm_hero_btn1_text',h.hero.btn1?.text);setInput('hm_hero_btn1_link',h.hero.btn1?.link);setInput('hm_hero_btn2_text',h.hero.btn2?.text);setInput('hm_hero_btn2_link',h.hero.btn2?.link);(h.hero.stats||[]).forEach((st,i)=>{setInput(`hm_stat${i+1}_num`,st.num);setInput(`hm_stat${i+1}_label`,st.label);});setInput('hm_why_badge',h.why.badge);setInput('hm_why_title',h.why.title);setInput('hm_why_desc',h.why.desc);setInput('hm_why_badge_num',h.why.badgeNum);setInput('hm_why_badge_label',h.why.badgeLabel);setInput('hm_steps_badge',h.steps.badge);setInput('hm_steps_title',h.steps.title);setInput('hm_steps_desc',h.steps.desc);setInput('hm_gallery_badge',h.gallery.badge);setInput('hm_gallery_title',h.gallery.title);setInput('hm_gallery_desc',h.gallery.desc);setInput('hm_areas_badge',h.areas.badge);setInput('hm_areas_title',h.areas.title);setInput('hm_areas_desc',h.areas.desc);setInput('hm_cta_title',h.cta.title);setInput('hm_cta_desc',h.cta.desc);(h.cta.buttons||[]).forEach((b,i)=>{setInput(`hm_cta_btn${i+1}_text`,b.text);setInput(`hm_cta_btn${i+1}_link`,b.link);setInput(`hm_cta_btn${i+1}_show`,String(b.show!==false));});const hp=document.getElementById('hm_hero_image_preview');if(hp){hp.style.display=h.hero.image?'block':'none';hp.src=h.hero.image||'';}const wp=document.getElementById('hm_why_image_preview');if(wp){wp.style.display=h.why.image?'block':'none';wp.src=h.why.image||'';}renderHomeLists();}
function collectHomeSettings(){const h=getHomeSettings();h.hero={...h.hero,badge:getInput('hm_hero_badge'),title:getInput('hm_hero_title'),desc:getInput('hm_hero_desc'),btn1:{text:getInput('hm_hero_btn1_text'),link:getInput('hm_hero_btn1_link')},btn2:{text:getInput('hm_hero_btn2_text'),link:getInput('hm_hero_btn2_link')},stats:[1,2,3].map(i=>({num:getInput(`hm_stat${i}_num`),label:getInput(`hm_stat${i}_label`)}))};h.why={...h.why,badge:getInput('hm_why_badge'),title:getInput('hm_why_title'),desc:getInput('hm_why_desc'),badgeNum:getInput('hm_why_badge_num'),badgeLabel:getInput('hm_why_badge_label')};h.steps={...h.steps,badge:getInput('hm_steps_badge'),title:getInput('hm_steps_title'),desc:getInput('hm_steps_desc')};h.gallery={...h.gallery,badge:getInput('hm_gallery_badge'),title:getInput('hm_gallery_title'),desc:getInput('hm_gallery_desc')};h.areas={...h.areas,badge:getInput('hm_areas_badge'),title:getInput('hm_areas_title'),desc:getInput('hm_areas_desc')};h.cta={...h.cta,title:getInput('hm_cta_title'),desc:getInput('hm_cta_desc')};h.cta.buttons=(h.cta.buttons||defaultHomeSettings.cta.buttons).map((b,i)=>({...b,text:getInput(`hm_cta_btn${i+1}_text`),link:getInput(`hm_cta_btn${i+1}_link`),show:getInput(`hm_cta_btn${i+1}_show`)==='true'}));return h;}
function saveHomeSettings(){DB.set('homeSettings',collectHomeSettings());renderSite();loadHomeManager();showNotif('تم حفظ الصفحة الرئيسية وتطبيق التعديلات فورًا ✅');}
function previewHomePage(){saveHomeSettings();goToSite();window.scrollTo({top:0,behavior:'smooth'});}
function resetHomeDefaults(){if(confirm('هل تريد استرجاع القيم الافتراضية للصفحة الرئيسية؟')){DB.set('homeSettings',cloneHomeDefaults());renderSite();loadHomeManager();showNotif('تم استرجاع الافتراضي ✅');}}
function listRef(h,type){if(type==='whyFeatures')return h.why.features;if(type==='steps')return h.steps.items;if(type==='gallery')return h.gallery.items;if(type==='areas')return h.areas.items;}
function renderHomeLists(){const h=getHomeSettings();renderRepeater('whyFeatures',h.why.features||[]);renderRepeater('steps',h.steps.items||[]);renderRepeater('gallery',h.gallery.items||[]);renderRepeater('areas',h.areas.items||[]);}
function repBtns(type,i){return `<div class="repeater-actions"><button class="action-btn view" onclick="moveHomeItem('${type}',${i},-1)" title="أعلى"><i class="fas fa-arrow-up"></i></button><button class="action-btn view" onclick="moveHomeItem('${type}',${i},1)" title="أسفل"><i class="fas fa-arrow-down"></i></button><button class="action-btn delete" onclick="deleteHomeItem('${type}',${i})" title="حذف"><i class="fas fa-trash"></i></button></div>`;}
function renderRepeater(type,items){const box=document.getElementById(`hm_${type}_list`);if(!box)return;box.innerHTML=items.map((it,i)=>{if(type==='areas')return `<div class="repeater-item"><div class="repeater-head"><strong>مدينة ${i+1}</strong>${repBtns(type,i)}</div><div class="form-grid"><div class="form-group-admin"><label>الأيقونة</label><input value="${it.icon||''}" onchange="updateHomeItem('${type}',${i},'icon',this.value)"></div><div class="form-group-admin"><label>اسم المدينة</label><input value="${it.title||''}" onchange="updateHomeItem('${type}',${i},'title',this.value)"></div></div><div class="form-group-admin"><label>الوصف</label><input value="${it.desc||''}" onchange="updateHomeItem('${type}',${i},'desc',this.value)"></div></div>`;if(type==='gallery')return `<div class="repeater-item"><div class="repeater-head"><strong>صورة ${i+1}</strong>${repBtns(type,i)}</div><div class="form-grid"><div class="form-group-admin"><label>عنوان الصورة</label><input value="${it.title||''}" onchange="updateHomeItem('${type}',${i},'title',this.value)"></div><div class="form-group-admin"><label>تصنيف الصورة</label><input value="${it.cat||''}" onchange="updateHomeItem('${type}',${i},'cat',this.value)"></div><div class="form-group-admin"><label>أيقونة placeholder</label><input value="${it.icon||'fa-image'}" onchange="updateHomeItem('${type}',${i},'icon',this.value)"></div><div class="form-group-admin"><label>رفع/استبدال الصورة</label><input type="file" accept="image/*" onchange="uploadHomeImage(event,'gallery','image',${i})">${it.image?`<img src="${it.image}" class="img-preview-small"><button class="admin-btn danger" style="margin-top:8px" onclick="deleteHomeImage('gallery',${i})"><i class="fas fa-trash"></i> حذف صورة</button>`:''}</div></div></div>`;return `<div class="repeater-item"><div class="repeater-head"><strong>${type==='steps'?'خطوة':'ميزة'} ${i+1}</strong>${repBtns(type,i)}</div><div class="form-grid"><div class="form-group-admin"><label>الأيقونة Font Awesome</label><input value="${it.icon||''}" onchange="updateHomeItem('${type}',${i},'icon',this.value)"></div><div class="form-group-admin"><label>العنوان</label><input value="${it.title||''}" onchange="updateHomeItem('${type}',${i},'title',this.value)"></div></div><div class="form-group-admin"><label>الوصف</label><textarea onchange="updateHomeItem('${type}',${i},'desc',this.value)">${it.desc||''}</textarea></div></div>`;}).join('');}
function updateHomeItem(type,i,key,val){const h=collectHomeSettings();const arr=listRef(h,type);if(arr&&arr[i]){arr[i][key]=val;DB.set('homeSettings',h);renderSite();}}
function addHomeItem(type){const h=collectHomeSettings();const arr=listRef(h,type);const base=type==='gallery'?{title:'صورة جديدة',cat:'عام',icon:'fa-image',image:''}:type==='areas'?{icon:'📍',title:'مدينة جديدة',desc:'وصف المدينة'}:{icon:'fa-check',title:'عنوان جديد',desc:'وصف مختصر'};arr.push(base);DB.set('homeSettings',h);renderHomeLists();renderSite();}
function deleteHomeItem(type,i){const h=collectHomeSettings();const arr=listRef(h,type);if(arr&&confirm('حذف هذا العنصر؟')){arr.splice(i,1);DB.set('homeSettings',h);renderHomeLists();renderSite();}}
function moveHomeItem(type,i,dir){const h=collectHomeSettings();const arr=listRef(h,type);if(!arr)return;const ni=i+dir;if(ni<0||ni>=arr.length)return;[arr[i],arr[ni]]=[arr[ni],arr[i]];DB.set('homeSettings',h);renderHomeLists();renderSite();}
function deleteHomeImage(section,index){const h=collectHomeSettings();if(section==='gallery')h.gallery.items[index].image='';if(section==='hero')h.hero.image='';if(section==='why')h.why.image='';DB.set('homeSettings',h);loadHomeManager();renderSite();showNotif('تم حذف الصورة');}
function uploadHomeImage(e,section,key,index){const file=e.target.files&&e.target.files[0];readAdminImage(file,data=>{const h=collectHomeSettings();if(section==='hero')h.hero.image=data;if(section==='why')h.why.image=data;if(section==='gallery')h.gallery.items[index].image=data;DB.set('homeSettings',h);loadHomeManager();renderSite();showNotif('تم رفع الصورة وتطبيقها ✅');});}

// --- Hero Settings ---
function saveHeroSettings(){
  const data={title:document.getElementById('heroTitle').value,desc:document.getElementById('heroDesc').value,cta1:document.getElementById('heroCTA1').value,cta2:document.getElementById('heroCTA2').value,stat1:document.getElementById('stat1').value,stat2:document.getElementById('stat2').value,stat3:document.getElementById('stat3').value};

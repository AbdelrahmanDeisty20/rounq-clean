          <option>تعقيم وتطهير</option><option>تنظيف عميق</option><option>تنظيف مكاتب</option>
        </select>
      </div>
    </div>
    <div class="form-group"><label>التاريخ المناسب</label><input type="date" id="reqDate"></div>
    <div class="form-group"><label>ملاحظات إضافية</label><textarea id="reqNotes" placeholder="أي تفاصيل إضافية تودّ ذكرها..."></textarea></div>

  {id:1, name:'الباقة الأساسية', oldPrice:249, newPrice:179, status:'active', features:'تنظيف 3 غرف\nتنظيف الصالة\nتنظيف مطبخ واحد\nتنظيف حمامين'},
  {id:2, name:'الباقة الذهبية ⭐', oldPrice:449, newPrice:319, status:'active', features:'تنظيف شقة كاملة\nتنظيف الكنب\nتنظيف السجاد\nتعقيم وتطهير\nخدمة مميزة'},
  {id:3, name:'الباقة الماسية 💎', oldPrice:699, newPrice:499, status:'active', features:'تنظيف فيلا كاملة\nتنظيف كنب وسجاد\nتنظيف بعد تشطيب\nتعقيم شامل\nضمان الجودة\nخدمة VIP'},
